<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alifio's Chatbot</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <style>
        :root {
            --deep-bg: #111111;
            --glass-bg: rgba(30, 30, 46, 0.6);
            --aether-blue: #00E5FF;
            --luminal-violet: #BC13FE;
            --gold-accent: #D4AF37;
            --text-primary: #F8FAF8;
            --text-secondary: #94A3B8;
            --transition-main: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        }

        body {
            background-color: var(--deep-bg);
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(0, 229, 255, 0.05) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(188, 19, 254, 0.05) 0%, transparent 40%),
                linear-gradient(135deg, var(--deep-bg) 0%, #1a1a2e 100%);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-primary);
            min-height: 100vh;
            margin: 0;
        }

        .navbar-alifio {
            background: rgba(17, 17, 17, 0.8);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
            padding: 1.5rem 0;
        }

        .brand-icon-wrapper {
            background: linear-gradient(135deg, var(--gold-accent), #B58B2C);
            width: 45px; height: 45px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.3);
        }

        .brand-name {
            font-weight: 800; font-size: 1.75rem; color: var(--text-primary);
            letter-spacing: 0.1rem;
        }
        .brand-subtitle { font-weight: 400; font-size: 0.85rem; color: var(--gold-accent); display: block; margin-top: -3px; }

        .glass-card-premium {
            background: var(--glass-bg);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 2rem;
            padding: 2.5rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            transition: var(--transition-main);
        }

        .chat-window {
            height: 450px;
            overflow-y: auto;
            border-radius: 1.5rem;
            background: rgba(17, 17, 17, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.03);
            padding: 2rem;
            margin-bottom: 2rem;
        }

        .chat-bubble-ai {
            background: rgba(56, 189, 248, 0.08);
            border-left: 3px solid var(--aether-blue);
            padding: 1.2rem;
            border-radius: 0 1.2rem 1.2rem 1.2rem;
            margin-bottom: 1.5rem;
            max-width: 85%;
            align-self: flex-start;
            color: #e2e8f0;
            line-height: 1.6;
        }

        .chat-bubble-ai p:last-child {
            margin-bottom: 0;
        }

        .chat-bubble-user {
            background: rgba(188, 19, 254, 0.1);
            border-right: 3px solid var(--luminal-violet);
            padding: 1rem 1.2rem;
            border-radius: 1.2rem 0 1.2rem 1.2rem;
            margin-bottom: 1.5rem;
            max-width: 85%;
            margin-left: auto;
            text-align: left;
            color: var(--text-primary);
            line-height: 1.6;
        }

        .form-control-premium {
            background-color: rgba(17, 17, 17, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 1.25rem;
            color: var(--text-primary);
            padding: 1.25rem 1.5rem;
            font-size: 1.1rem;
            transition: var(--transition-main);
        }
        
        .form-control-premium:focus {
            background-color: rgba(17, 17, 17, 0.8);
            border-color: var(--aether-blue);
            box-shadow: 0 0 15px rgba(0, 229, 255, 0.2);
            color: var(--text-primary);
        }

        .btn-premium-send {
            background: linear-gradient(135deg, var(--aether-blue) 0%, var(--luminal-violet) 100%);
            border: none;
            border-radius: 1.25rem;
            color: var(--deep-bg);
            font-weight: 700;
            padding: 0 2.5rem;
            transition: var(--transition-main);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-premium-send:hover {
            transform: scale(1.02);
            box-shadow: 0 0 25px rgba(0, 229, 255, 0.4);
            color: var(--deep-bg);
        }

        .typing-indicator {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 0.2rem 0;
        }

        .typing-indicator span {
            width: 6px;
            height: 6px;
            background-color: var(--aether-blue);
            border-radius: 50%;
            animation: bounce 1.4s infinite ease-in-out both;
        }

        .typing-indicator span:nth-child(1) { animation-delay: -0.32s; }
        .typing-indicator span:nth-child(2) { animation-delay: -0.16s; }

        @keyframes bounce {
            0%, 80%, 100% { transform: scale(0); }
            40% { transform: scale(1.0); }
        }
    </style>
</head>
<body>

<nav class="navbar navbar-alifio">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <div class="brand-icon-wrapper">
                <i class="fas fa-robot text-white fs-4"></i>
            </div>
            <div>
                <span class="brand-name">ALIFIO</span>
                <span class="brand-subtitle">Chatbot</span>
            </div>
        </div>
    </div>
</nav>

<div class="container py-5 mt-3">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            <div class="glass-card-premium">
                <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
                    <i class="fas fa-brain text-info"></i>
                    AI Chatbot
                </h5>
                
                <div id="chat-window" class="chat-window d-flex flex-column">
                    <div class="chat-bubble-ai">
                        Halo, Ada yang bisa saya bantu hari ini?
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-12">
                        <input type="text" id="ai-input" class="form-control-premium w-100" placeholder="Ketik pesan Anda di sini..." onkeypress="handleKeyPress(event)">
                    </div>
                    <div class="col-12 d-flex justify-content-end">
                        <button class="btn btn-premium-send py-3 px-5" onclick="askAI()">
                            Kirim <i class="fas fa-paper-plane ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function handleKeyPress(event) {
        if (event.key === 'Enter') {
            askAI();
        }
    }

    async function askAI() {
        const input = document.getElementById('ai-input');
        const windowChat = document.getElementById('chat-window');
        if(!input.value.trim()) return;

        const userMsg = input.value;
        windowChat.innerHTML += `<div class="chat-bubble-user">${userMsg}</div>`;
        input.value = '';
        
        const loadingId = 'loading-' + Date.now();
        windowChat.innerHTML += `
            <div class="chat-bubble-ai" id="${loadingId}">
                <div class="typing-indicator">
                    <span></span><span></span><span></span>
                </div>
            </div>`;
        
        windowChat.scrollTop = windowChat.scrollHeight;

        try {
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: userMsg })
            });
            const data = await response.json();
            
            const loadingBubble = document.getElementById(loadingId);
            if (loadingBubble) {
                loadingBubble.innerHTML = marked.parse(data.reply || data.error || 'Terjadi kesalahan luar.');
            }
        } catch (e) {
            const loadingBubble = document.getElementById(loadingId);
            if (loadingBubble) {
                loadingBubble.innerHTML = '<span class="text-danger">Gagal memuat balasan. Pastikan koneksi dan API Key benar.</span>';
            }
        }
    }
</script>
</body>
</html>